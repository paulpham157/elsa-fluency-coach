{
  "manifest_version": 3,
  "name": "Fluency Coach",
  "version": "1.0",
  "description": "Extracts speech analysis data from Elsa Speak and generates structured reports for Claude AI",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fluency Coach"
  },
  "content_scripts": [
    {
      "matches": ["https://speechanalyzer.elsaspeak.com/*"],
      "js": ["lib/extract.js", "content.js"]
    }
  ],
  "permissions": ["activeTab", "tabs", "storage"]
}
